<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:CRT"
        x:Class="CRT.ComponentContributionWindow"
        Title="Component contribution"
        Width="1400"
        Height="900"
        MinWidth="900"
        MinHeight="600"
        Background="{DynamicResource Main_Bg}"
        Foreground="{DynamicResource Main_Fg}">

	<Window.Styles>
		<Style Selector="Expander">
			<Setter Property="HorizontalAlignment" Value="Stretch" />
			<Setter Property="HorizontalContentAlignment" Value="Stretch" />
			<Setter Property="Background" Value="{DynamicResource Main_Bg}" />
		</Style>

		<!-- Content area stays on the normal window background -->
		<Style Selector="Expander /template/ ContentPresenter">
			<Setter Property="Background" Value="{DynamicResource Main_Bg}" />
		</Style>

		<!-- Only the top expand/collapse header gets the alternate background -->
		<Style Selector="Expander /template/ ToggleButton">
			<Setter Property="Background" Value="{DynamicResource Table_Header_Bg}" />
			<Setter Property="Foreground" Value="{DynamicResource Table_Header_Fg}" />
		</Style>

		<Style Selector="Expander /template/ Border">
			<Setter Property="Background" Value="{DynamicResource Main_Bg}" />
		</Style>

		<Style Selector="Button.HighlightAddRowButton">
			<Setter Property="Background" Value="{DynamicResource Button_Highlighted_Bg}" />
			<Setter Property="Foreground" Value="{DynamicResource Button_Highlighted_Fg}" />
			<Setter Property="Padding" Value="14,8" />
		</Style>
	</Window.Styles>

	<Grid RowDefinitions="Auto,*,Auto" Margin="16">

		<Border Grid.Row="0"
		        BorderBrush="{DynamicResource Panel_Border}"
		        BorderThickness="1"
		        CornerRadius="6"
		        Padding="12"
		        Margin="0,0,0,12">
			<Grid ColumnDefinitions="*,24,*">
				<StackPanel Grid.Column="0" Spacing="4">
					<TextBlock Text="Component contribution editor"
					           FontSize="20"
					           FontWeight="Bold" />
					<TextBlock x:Name="ComponentTitleTextBlock"
					           FontSize="14"
					           FontWeight="SemiBold"
					           Foreground="{DynamicResource Main_Header_Fg}" />
					<TextBlock x:Name="HardwareContextTextBlock"
							   FontSize="12"
							   FontFamily="Consolas,Courier New,monospace"
							   Foreground="{DynamicResource Main_Header_Fg}" />
					<TextBlock x:Name="BoardContextTextBlock"
							   FontSize="12"
							   FontFamily="Consolas,Courier New,monospace"
							   Foreground="{DynamicResource Main_Header_Fg}" />
					<TextBlock x:Name="RegionContextTextBlock"
							   FontSize="12"
							   FontFamily="Consolas,Courier New,monospace"
							   Foreground="{DynamicResource Main_Header_Fg}" />
				</StackPanel>
			</Grid>
		</Border>

		<ScrollViewer x:Name="MainScrollViewer"
				  Grid.Row="1"
				  VerticalScrollBarVisibility="Auto"
				  HorizontalScrollBarVisibility="Disabled">
			<StackPanel Spacing="16">

				<Border BorderBrush="{DynamicResource Panel_Border}"
				        BorderThickness="1"
				        CornerRadius="6"
				        Padding="12">
					<StackPanel Spacing="6">
						<TextBlock Text="How this works"
						           FontSize="15"
						           FontWeight="Bold" />
						<TextBlock TextWrapping="Wrap"
						           Foreground="{DynamicResource Main_Fg}">
							All data below is editable suggestions. The current values are preloaded from the board data. When submitted, the full edited payload is sent to the developer for review together with your comment. Please do provide your email, in case of any follow-up questions or confirmations that this has been accepted or rejected.
						</TextBlock>
					</StackPanel>
				</Border>

				<Border BorderBrush="{DynamicResource Panel_Border}"
				        BorderThickness="1"
				        CornerRadius="6"
				        Padding="12">
					<Expander IsExpanded="True">
						<Expander.Header>
							<TextBlock Text='Component'
							           FontSize="15"
							           FontWeight="Bold" />
						</Expander.Header>

						<StackPanel Spacing="10"
						            Margin="0,10,0,0"
						            HorizontalAlignment="Stretch">
							<TextBlock Text="Component"
							           FontSize="12"
							           Foreground="{DynamicResource Main_Header_Fg}" />

							<ItemsControl x:Name="ComponentRowsItemsControl">
								<ItemsControl.ItemTemplate>
									<DataTemplate x:DataType="local:ContributionComponentRow">
										<Border BorderBrush="{DynamicResource Panel_Border}"
										        BorderThickness="1"
										        CornerRadius="4"
										        Padding="8"
										        Margin="0,0,0,8">
											<Grid ColumnDefinitions="*,12,*">
												<StackPanel Grid.Column="0" Spacing="4">
													<TextBlock Text="Board label" FontSize="11" />
													<TextBox Text="{Binding BoardLabel}" />

													<TextBlock Text="Friendly name" FontSize="11" />
													<TextBox Text="{Binding FriendlyName}" />

													<TextBlock Text="Technical name or value" FontSize="11" />
													<TextBox Text="{Binding TechnicalNameOrValue}" />

													<TextBlock Text="Part-number" FontSize="11" />
													<TextBox Text="{Binding PartNumber}" />
												</StackPanel>

												<StackPanel Grid.Column="2" Spacing="4">
													<TextBlock Text="Category" FontSize="11" />
													<TextBox Text="{Binding Category}" />

													<TextBlock Text="Region" FontSize="11" />
													<TextBox Text="{Binding Region}" />

													<TextBlock Text="Short description" FontSize="11" />
													<TextBox Text="{Binding Description}"
													         AcceptsReturn="True"
													         TextWrapping="Wrap"
													         MinHeight="84" />
												</StackPanel>
											</Grid>
										</Border>
									</DataTemplate>
								</ItemsControl.ItemTemplate>
							</ItemsControl>
						</StackPanel>
					</Expander>
				</Border>

				<Border BorderBrush="{DynamicResource Panel_Border}"
						BorderThickness="1"
						CornerRadius="6"
						Padding="12">
					<Expander IsExpanded="False">
						<Expander.Header>
							<StackPanel Orientation="Horizontal" Spacing="4">
								<TextBlock Text="Component images"
										   FontSize="15"
										   FontWeight="Bold" />
								<TextBlock x:Name="ComponentImagesCountTextBlock"
										   Text="(0)"
										   FontSize="15"
										   FontWeight="Bold" />
							</StackPanel>
						</Expander.Header>

					<StackPanel Spacing="10"
						            Margin="0,10,0,0"
						            HorizontalAlignment="Stretch">
							<Grid ColumnDefinitions="*,Auto"
							      HorizontalAlignment="Stretch"
							      Margin="0,0,0,16">
								<TextBlock x:Name="ComponentImagesRegionTextBlock"
									   FontSize="12"
									   VerticalAlignment="Center"
									   Foreground="{DynamicResource Main_Header_Fg}" />
								<Button Grid.Column="1"
								        Classes="HighlightAddRowButton"
								        Content="Add new component image"
								        Click="OnAddComponentImageRowClick" />
							</Grid>

							<ItemsControl x:Name="ComponentImageRowsItemsControl">
								<ItemsControl.ItemTemplate>
									<DataTemplate x:DataType="local:ContributionComponentImageRow">
										<Border BorderBrush="{DynamicResource Panel_Border}"
										        BorderThickness="1"
										        CornerRadius="4"
										        Padding="8"
										        Margin="0,0,0,8">
											<Grid ColumnDefinitions="320,16,*">
												<Grid Grid.Column="0"
													  Height="260"
													  Margin="6"
													  ClipToBounds="True"
													  Background="Transparent">
													<Viewbox Stretch="Uniform"
															 HorizontalAlignment="Stretch"
															 VerticalAlignment="Stretch">
														<Border Background="{DynamicResource ComponentPopup_ImageTransparent_Bg}">
															<Image Source="{Binding PreviewImage}"
																   Stretch="None" />
														</Border>
													</Viewbox>
												</Grid>

												<Grid Grid.Column="2" ColumnDefinitions="*,12,*">
													<StackPanel Grid.Column="0" Spacing="4">
														<TextBlock Text="Board label" FontSize="11" />
														<TextBox Text="{Binding BoardLabel}" />

														<TextBlock Text="Region" FontSize="11" />
														<TextBox Text="{Binding Region}" />

														<TextBlock Text="Pin" FontSize="11" />
														<TextBox Text="{Binding Pin}" />

														<TextBlock Text="Name" FontSize="11" />
														<TextBox Text="{Binding Name}" />
													</StackPanel>

													<StackPanel Grid.Column="2" Spacing="4">
														<TextBlock Text="Expected oscilloscope reading" FontSize="11" />
														<TextBox Text="{Binding ExpectedOscilloscopeReading}" />

														<TextBlock Text="File" FontSize="11" />
														<TextBox Text="{Binding File}"
														         Tag="{Binding}"
														         IsReadOnly="True"
														         Cursor="Hand"
														         PointerReleased="OnFileTextBoxPointerReleased" />

														<TextBlock Text="Note" FontSize="11" />
														<TextBox Text="{Binding Note}"
														         AcceptsReturn="True"
														         TextWrapping="Wrap"
														         MinHeight="84" />

														<Button Content="Remove image"
														        HorizontalAlignment="Right"
														        Tag="{Binding}"
														        Click="OnRemoveComponentImageRowClick" />
													</StackPanel>
												</Grid>
											</Grid>
										</Border>
									</DataTemplate>
								</ItemsControl.ItemTemplate>
							</ItemsControl>
						</StackPanel>
					</Expander>
				</Border>

				<Border BorderBrush="{DynamicResource Panel_Border}"
						BorderThickness="1"
						CornerRadius="6"
						Padding="12">
					<Expander IsExpanded="False">
						<Expander.Header>
							<StackPanel Orientation="Horizontal" Spacing="4">
								<TextBlock Text="Component local files"
										   FontSize="15"
										   FontWeight="Bold" />
								<TextBlock x:Name="ComponentLocalFilesCountTextBlock"
										   Text="(0)"
										   FontSize="15"
										   FontWeight="Bold" />
							</StackPanel>
						</Expander.Header>

						<StackPanel Spacing="10"
						            Margin="0,10,0,0"
						            HorizontalAlignment="Stretch">
							<Grid ColumnDefinitions="*,Auto" HorizontalAlignment="Stretch">
								<StackPanel Grid.Column="0" Spacing="2">
									<TextBlock Text="Describe all files specifically for this component."
											   FontSize="12"
											   Foreground="{DynamicResource Main_Header_Fg}" />
									<TextBlock Text="This could e.g. be datasheets, technical instructions, manuals or whatever is relevant specifically for this component."
											   FontSize="12"
											   TextWrapping="Wrap"
											   Foreground="{DynamicResource Main_Header_Fg}" />
								</StackPanel>
								<Button Grid.Column="1"
										Classes="HighlightAddRowButton"
										Content="Add new component file"
										Click="OnAddComponentLocalFileRowClick" />
							</Grid>

							<Grid ColumnDefinitions="180,12,360,12,*,12,Auto"
									  Margin="0,0,0,6"
									  HorizontalAlignment="Stretch">
								<TextBlock Text="Board label" FontSize="11" FontWeight="Bold" />
								<TextBlock Grid.Column="2" Text="Name" FontSize="11" FontWeight="Bold" />
								<TextBlock Grid.Column="4" Text="File" FontSize="11" FontWeight="Bold" />
							</Grid>

							<ItemsControl x:Name="ComponentLocalFileRowsItemsControl">
								<ItemsControl.ItemTemplate>
									<DataTemplate x:DataType="local:ContributionComponentLocalFileRow">
										<Border BorderThickness="0"
										        Background="Transparent"
										        Padding="0,4">
											<Grid ColumnDefinitions="180,12,360,12,*,12,Auto"
											      HorizontalAlignment="Stretch">
												<TextBox Text="{Binding BoardLabel}" />
												<TextBox Grid.Column="2" Text="{Binding Name}" />
												<TextBox Grid.Column="4"
												         Text="{Binding File}"
												         Tag="{Binding}"
												         IsReadOnly="True"
												         Cursor="Hand"
												         PointerReleased="OnFileTextBoxPointerReleased" />
												<Button Grid.Column="6"
												        Content="Remove"
												        Tag="{Binding}"
												        Click="OnRemoveComponentLocalFileRowClick" />
											</Grid>
										</Border>
									</DataTemplate>
								</ItemsControl.ItemTemplate>
							</ItemsControl>
						</StackPanel>
					</Expander>
				</Border>

				<Border BorderBrush="{DynamicResource Panel_Border}"
						BorderThickness="1"
						CornerRadius="6"
						Padding="12">
					<Expander IsExpanded="False">
						<Expander.Header>
							<StackPanel Orientation="Horizontal" Spacing="4">
								<TextBlock Text="Component links"
										   FontSize="15"
										   FontWeight="Bold" />
								<TextBlock x:Name="ComponentLinksCountTextBlock"
										   Text="(0)"
										   FontSize="15"
										   FontWeight="Bold" />
							</StackPanel>
						</Expander.Header>

						<StackPanel Spacing="10"
						            Margin="0,10,0,0"
						            HorizontalAlignment="Stretch">
							<Grid ColumnDefinitions="*,Auto" HorizontalAlignment="Stretch">
								<StackPanel Grid.Column="0" Spacing="2">
									<TextBlock Text="Describe all links specifically for this component."
											   FontSize="12"
											   Foreground="{DynamicResource Main_Header_Fg}" />
									<TextBlock Text="This could links for technical instructions or basically any link relevant specifically for this component."
											   FontSize="12"
											   TextWrapping="Wrap"
											   Foreground="{DynamicResource Main_Header_Fg}" />
								</StackPanel>
								<Button Grid.Column="1"
										Classes="HighlightAddRowButton"
										Content="Add new component link"
										Click="OnAddComponentLinkRowClick" />
							</Grid>

							<Grid ColumnDefinitions="180,12,360,12,*,12,Auto"
								  Margin="0,0,0,6"
								  HorizontalAlignment="Stretch">
								<TextBlock Text="Board label" FontSize="11" FontWeight="Bold" />
								<TextBlock Grid.Column="2" Text="Name" FontSize="11" FontWeight="Bold" />
								<TextBlock Grid.Column="4" Text="URL" FontSize="11" FontWeight="Bold" />
							</Grid>

							<ItemsControl x:Name="ComponentLinkRowsItemsControl">
								<ItemsControl.ItemTemplate>
									<DataTemplate x:DataType="local:ContributionComponentLinkRow">
										<Border BorderThickness="0"
										        Background="Transparent"
										        Padding="0,4">
											<Grid ColumnDefinitions="180,12,360,12,*,12,Auto"
												HorizontalAlignment="Stretch">
												<TextBox Text="{Binding BoardLabel}" />
												<TextBox Grid.Column="2" Text="{Binding Name}" />
												<TextBox Grid.Column="4" Text="{Binding Url}" />
												<Button Grid.Column="6"
												        Content="Remove"
												        Tag="{Binding}"
												        Click="OnRemoveComponentLinkRowClick" />
											</Grid>
										</Border>
									</DataTemplate>
								</ItemsControl.ItemTemplate>
							</ItemsControl>
						</StackPanel>
					</Expander>
				</Border>

				<Border BorderBrush="{DynamicResource Panel_Border}"
						BorderThickness="1"
						CornerRadius="6"
						Padding="12">
					<Expander IsExpanded="False">
						<Expander.Header>
							<StackPanel Orientation="Horizontal" Spacing="4">
								<TextBlock Text="Board local files"
										   FontSize="15"
										   FontWeight="Bold" />
								<TextBlock x:Name="BoardLocalFilesCountTextBlock"
										   Text="(0)"
										   FontSize="15"
										   FontWeight="Bold" />
							</StackPanel>
						</Expander.Header>

						<StackPanel Spacing="10"
						            Margin="0,10,0,0"
						            HorizontalAlignment="Stretch">
							<Grid ColumnDefinitions="*,Auto" HorizontalAlignment="Stretch">
								<StackPanel Grid.Column="0" Spacing="2">
									<TextBlock Text="Describe all files specifically for the board."
											   FontSize="12"
											   Foreground="{DynamicResource Main_Header_Fg}" />
									<TextBlock Text="These files are more generic and cover e.g. service or troubleshooting manuals, that can be used for the entire board."
											   FontSize="12"
											   TextWrapping="Wrap"
											   Foreground="{DynamicResource Main_Header_Fg}" />
								</StackPanel>
								<Button Grid.Column="1"
										Classes="HighlightAddRowButton"
										Content="Add new board file"
										Click="OnAddBoardLocalFileRowClick" />
							</Grid>

							<Grid ColumnDefinitions="180,12,360,12,*,12,Auto"
								  Margin="0,0,0,6"
								  HorizontalAlignment="Stretch">
								<TextBlock Text="Category" FontSize="11" FontWeight="Bold" />
								<TextBlock Grid.Column="2" Text="Name" FontSize="11" FontWeight="Bold" />
								<TextBlock Grid.Column="4" Text="File" FontSize="11" FontWeight="Bold" />
							</Grid>

							<ItemsControl x:Name="BoardLocalFileRowsItemsControl">
								<ItemsControl.ItemTemplate>
									<DataTemplate x:DataType="local:ContributionBoardLocalFileRow">
										<Border BorderThickness="0"
										        Background="Transparent"
										        Padding="0,4">
											<Grid ColumnDefinitions="180,12,360,12,*,12,Auto"
												HorizontalAlignment="Stretch">
												<TextBox Text="{Binding Category}" />
												<TextBox Grid.Column="2" Text="{Binding Name}" />
												<TextBox Grid.Column="4"
												         Text="{Binding File}"
												         Tag="{Binding}"
												         IsReadOnly="True"
												         Cursor="Hand"
												         PointerReleased="OnFileTextBoxPointerReleased" />
												<Button Grid.Column="6"
												        Content="Remove"
												        Tag="{Binding}"
												        Click="OnRemoveBoardLocalFileRowClick" />
											</Grid>
										</Border>
									</DataTemplate>
								</ItemsControl.ItemTemplate>
							</ItemsControl>
						</StackPanel>
					</Expander>
				</Border>

				<Border BorderBrush="{DynamicResource Panel_Border}"
						BorderThickness="1"
						CornerRadius="6"
						Padding="12">
					<Expander IsExpanded="False">
						<Expander.Header>
							<StackPanel Orientation="Horizontal" Spacing="4">
								<TextBlock Text="Board links"
										   FontSize="15"
										   FontWeight="Bold" />
								<TextBlock x:Name="BoardLinksCountTextBlock"
										   Text="(0)"
										   FontSize="15"
										   FontWeight="Bold" />
							</StackPanel>
						</Expander.Header>

						<StackPanel Spacing="10"
						            Margin="0,10,0,0"
						            HorizontalAlignment="Stretch">
							<Grid ColumnDefinitions="*,Auto" HorizontalAlignment="Stretch">
								<StackPanel Grid.Column="0" Spacing="2">
									<TextBlock Text="Describe all links specifically for the board."
											   FontSize="12"
											   Foreground="{DynamicResource Main_Header_Fg}" />
									<TextBlock Text="These links could typically be for content covering this board, e.g. board repairing histories or YouTube videos specifically for this board."
											   FontSize="12"
											   TextWrapping="Wrap"
											   Foreground="{DynamicResource Main_Header_Fg}" />
								</StackPanel>
								<Button Grid.Column="1"
										Classes="HighlightAddRowButton"
										Content="Add new board link"
										Click="OnAddBoardLinkRowClick" />
							</Grid>

							<Grid ColumnDefinitions="180,12,360,12,*,12,Auto"
									  Margin="0,0,0,6"
									  HorizontalAlignment="Stretch">
								<TextBlock Text="Category" FontSize="11" FontWeight="Bold" />
								<TextBlock Grid.Column="2" Text="Name" FontSize="11" FontWeight="Bold" />
								<TextBlock Grid.Column="4" Text="URL" FontSize="11" FontWeight="Bold" />
							</Grid>

							<ItemsControl x:Name="BoardLinkRowsItemsControl">
								<ItemsControl.ItemTemplate>
									<DataTemplate x:DataType="local:ContributionBoardLinkRow">
										<Border BorderThickness="0"
										        Background="Transparent"
										        Padding="0,4">
											<Grid ColumnDefinitions="180,12,360,12,*,12,Auto"
												HorizontalAlignment="Stretch">
												<TextBox Text="{Binding Category}" />
												<TextBox Grid.Column="2" Text="{Binding Name}" />
												<TextBox Grid.Column="4" Text="{Binding Url}" />
												<Button Grid.Column="6"
												        Content="Remove"
												        Tag="{Binding}"
												        Click="OnRemoveBoardLinkRowClick" />
											</Grid>
										</Border>
									</DataTemplate>
								</ItemsControl.ItemTemplate>
							</ItemsControl>
						</StackPanel>
					</Expander>
				</Border>

				<Border BorderBrush="{DynamicResource Panel_Border}"
				        BorderThickness="1"
				        CornerRadius="6"
				        Padding="12"
				        Margin="0,0,0,4">
					<StackPanel Spacing="6">
						<TextBlock Text="Mandatory comment for your changes"
						           FontSize="15"
						           FontWeight="Bold" />
						<TextBlock Text="Describe what you have changed, what was wrong or missing, and anything the developer should verify."
						           FontSize="11"
						           Foreground="{DynamicResource Main_Header_Fg}"
						           TextWrapping="Wrap" />
						<TextBlock Text="Also do document your specific board revision, as that maybe be important (if board has more revisions)."
								   FontSize="11"
								   Foreground="{DynamicResource Main_Header_Fg}"
								   TextWrapping="Wrap" />
						<TextBox x:Name="MandatoryCommentTextBox"
						         AcceptsReturn="True"
						         TextWrapping="Wrap"
						         MinHeight="180"
						         Background="{DynamicResource Main_TextField_Bg}"
						         Foreground="{DynamicResource Main_TextField_Fg}" />
					</StackPanel>
				</Border>

			</StackPanel>
		</ScrollViewer>

		<Grid Grid.Row="2" ColumnDefinitions="Auto,320,16,*,Auto" Margin="0,12,0,0">
			<TextBlock Grid.Column="0"
					   Text="Email address *:"
					   VerticalAlignment="Center"
					   FontSize="12"
					   Margin="0,0,8,0" />

			<TextBox x:Name="EmailTextBox"
					 Grid.Column="1"
					 Watermark="required@example.com"
					 Background="{DynamicResource Main_InputField_Bg}"
					 Foreground="{DynamicResource Main_InputField_Fg}"
					 VerticalAlignment="Center"
					 LostFocus="OnEmailTextBoxLostFocus" />

			<TextBlock x:Name="StatusTextBlock"
					   Grid.Column="3"
					   VerticalAlignment="Center"
					   FontWeight="Bold"
					   IsVisible="False">
				<TextBlock.Styles>
					<Style Selector="TextBlock.success">
						<Setter Property="Foreground" Value="{DynamicResource Feedback_SubmittedOk_Fg}" />
					</Style>
					<Style Selector="TextBlock.error">
						<Setter Property="Foreground" Value="{DynamicResource Feedback_SubmittedFail_Fg}" />
					</Style>
				</TextBlock.Styles>
			</TextBlock>

			<StackPanel Grid.Column="4"
						Orientation="Horizontal"
						Spacing="8">
				<Button Content="▲"
						Click="OnScrollToTopClick" />
				<Button Content="▼"
						Click="OnScrollToBottomClick" />
				<Button Content="Cancel"
						Click="OnCancelClick" />
				<Button x:Name="SubmitButton"
						Content="Send contribution update"
						Background="{DynamicResource Button_Highlighted_Bg}"
						Foreground="{DynamicResource Feedback_Submit_Fg}"
						Click="OnSubmitClick" />
			</StackPanel>
		</Grid>
	</Grid>
</Window>