<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:CRT"
             x:Class="CRT.TabResources">

	<UserControl.Styles>
		<Style Selector="Button.LinkButton">
			<Setter Property="Background" Value="Transparent" />
			<Setter Property="Foreground" Value="{DynamicResource Main_Link_Fg}" />
			<Setter Property="Padding" Value="0" />
			<Setter Property="BorderThickness" Value="0" />
			<Setter Property="Cursor" Value="Hand" />
			<Setter Property="HorizontalAlignment" Value="Left" />
			<Setter Property="HorizontalContentAlignment" Value="Left" />
			<Setter Property="VerticalAlignment" Value="Top" />
			<Setter Property="VerticalContentAlignment" Value="Top" />
			<Setter Property="MinHeight" Value="0" />
		</Style>

		<Style Selector="Button.LinkButton /template/ ContentPresenter">
			<Setter Property="Background" Value="Transparent" />
		</Style>

		<Style Selector="Button.LinkButton:pointerover /template/ ContentPresenter">
			<Setter Property="Background" Value="Transparent" />
		</Style>

		<Style Selector="Button.LinkButton:pointerover TextBlock">
			<Setter Property="Foreground" Value="{DynamicResource Main_LinkHover_Fg}" />
		</Style>

		<Style Selector="Button.LinkButton:pressed /template/ ContentPresenter">
			<Setter Property="Background" Value="Transparent" />
		</Style>

		<Style Selector="Border.ResourceRow">
			<Setter Property="Background" Value="Transparent" />
		</Style>

		<Style Selector="Border.ResourceRow:pointerover">
			<Setter Property="Background" Value="{DynamicResource Table_RowHover_Bg}" />
		</Style>

		<Style Selector="TextBlock.ResourceHeaderText">
			<Setter Property="FontWeight" Value="Bold" />
			<Setter Property="FontSize" Value="12" />
			<Setter Property="Foreground" Value="{DynamicResource Main_Header_Fg}" />
		</Style>
	</UserControl.Styles>

	<ScrollViewer>
		<StackPanel Margin="16" Spacing="24">

			<TextBlock Text="Board specific resources for troubleshooting and information."
					   FontSize="14" />

			<!-- Local Files Section -->
			<StackPanel Spacing="8">
				<TextBlock Text="Local files"
						   FontSize="14"
						   FontWeight="Bold" />

					<Grid RowDefinitions="Auto,*">

						<Border Grid.Row="0"
						        Background="{DynamicResource Table_Bg}"
						        Padding="0,12,0,0">
							<Grid>
								<Grid.ColumnDefinitions>
									<ColumnDefinition Width="200" />
									<ColumnDefinition Width="*" />
								</Grid.ColumnDefinitions>

								<Grid Grid.Column="0">
									<Grid RowDefinitions="Auto,Auto">
										<TextBlock Grid.Row="0"
										           Classes="ResourceHeaderText"
										           Text="Category"
										           Margin="8,0,8,0" />
										<Border Grid.Row="1"
										        Height="1"
										        Background="{DynamicResource Table_BorderRowLine}"
										        Margin="8,4,8,8" />
									</Grid>
								</Grid>

								<Grid Grid.Column="1">
									<Grid RowDefinitions="Auto,Auto">
										<TextBlock Grid.Row="0"
										           Classes="ResourceHeaderText"
										           Text="Name"
										           Margin="8,0,8,0" />
										<Border Grid.Row="1"
										        Height="1"
										        Background="{DynamicResource Table_BorderRowLine}"
										        Margin="8,4,8,8" />
									</Grid>
								</Grid>
							</Grid>
						</Border>

						<ItemsControl Grid.Row="1"
						              x:Name="LocalFilesItemsControl"
						              Background="{DynamicResource Table_Bg}">
							<ItemsControl.ItemTemplate>
								<DataTemplate DataType="local:ResourceItem">
									<Border Classes="ResourceRow"
									        BorderBrush="{DynamicResource Table_BorderRowLine}"
									        BorderThickness="0,0,0,1"
									        Padding="0,4">
										<Grid>
											<Grid.ColumnDefinitions>
												<ColumnDefinition Width="200" />
												<ColumnDefinition Width="*" />
											</Grid.ColumnDefinitions>
											<SelectableTextBlock Grid.Column="0"
											                     Text="{Binding Category}"
											                     Foreground="{DynamicResource Table_Fg}"
											                     Margin="8,4,8,4"
											                     VerticalAlignment="Top"
											                     TextWrapping="Wrap" />
											<Button Grid.Column="1"
											        Classes="LinkButton"
											        Margin="8,4,8,4"
											        Command="{Binding OpenCommand}">
												<TextBlock Text="{Binding Name}" />
											</Button>
										</Grid>
									</Border>
								</DataTemplate>
							</ItemsControl.ItemTemplate>
						</ItemsControl>
					</Grid>

			</StackPanel>

			<!-- Web Links Section -->
			<StackPanel Spacing="8">
				<TextBlock Text="Links"
						   FontSize="14"
						   FontWeight="Bold" />

					<Grid RowDefinitions="Auto,*">

						<Border Grid.Row="0"
						        Background="{DynamicResource Table_Bg}"
						        Padding="0,12,0,0">
							<Grid>
								<Grid.ColumnDefinitions>
									<ColumnDefinition Width="200" />
									<ColumnDefinition Width="*" />
								</Grid.ColumnDefinitions>

								<Grid Grid.Column="0">
									<Grid RowDefinitions="Auto,Auto">
										<TextBlock Grid.Row="0"
										           Classes="ResourceHeaderText"
										           Text="Category"
										           Margin="8,0,8,0" />
										<Border Grid.Row="1"
										        Height="1"
										        Background="{DynamicResource Table_BorderRowLine}"
										        Margin="8,4,8,8" />
									</Grid>
								</Grid>

								<Grid Grid.Column="1">
									<Grid RowDefinitions="Auto,Auto">
										<TextBlock Grid.Row="0"
										           Classes="ResourceHeaderText"
										           Text="Name"
										           Margin="8,0,8,0" />
										<Border Grid.Row="1"
										        Height="1"
										        Background="{DynamicResource Table_BorderRowLine}"
										        Margin="8,4,8,8" />
									</Grid>
								</Grid>
							</Grid>
						</Border>

						<ItemsControl Grid.Row="1"
						              x:Name="WebLinksItemsControl"
						              Background="{DynamicResource Table_Bg}">
							<ItemsControl.ItemTemplate>
								<DataTemplate DataType="local:ResourceItem">
									<Border Classes="ResourceRow"
									        BorderBrush="{DynamicResource Table_BorderRowLine}"
									        BorderThickness="0,0,0,1"
									        Padding="0,4">
										<Grid>
											<Grid.ColumnDefinitions>
												<ColumnDefinition Width="200" />
												<ColumnDefinition Width="*" />
											</Grid.ColumnDefinitions>
											<SelectableTextBlock Grid.Column="0"
											                     Text="{Binding Category}"
											                     Foreground="{DynamicResource Table_Fg}"
											                     Margin="8,4,8,4"
											                     VerticalAlignment="Top"
											                     TextWrapping="Wrap" />
											<Button Grid.Column="1"
											        Classes="LinkButton"
											        Margin="8,4,8,4"
											        Command="{Binding OpenCommand}">
												<TextBlock Text="{Binding Name}" />
											</Button>
										</Grid>
									</Border>
								</DataTemplate>
							</ItemsControl.ItemTemplate>
						</ItemsControl>
					</Grid>
			</StackPanel>

		</StackPanel>
	</ScrollViewer>
</UserControl>